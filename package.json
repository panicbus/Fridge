{
  "name": "fridge",
  "version": "0.3.0",
  "description": "What's in your fridge? Get recipes.",
  "main": "dist-electron/main.js",
  "scripts": {
    "compile:electron": "tsc -p tsconfig.electron.json",
    "dev": "npm run compile:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build && npm run compile:electron",
    "package:dir": "npm run build && electron-builder --mac --dir --universal",
    "dist:mac": "npm run build && bash scripts/dist-mac-signed.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "electron": "npm run compile:electron && electron ."
  },
  "dependencies": {
    "axios": "^1.6.0",
    "pluralize": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  }
}
