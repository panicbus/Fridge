# Copy to .env and customize. Never commit real API keys.

# Optional: enable Spoonacular as an additional recipe source.
# Default off — the local trove + MealDB are sufficient.
# Requires a free API key from https://spoonacular.com/food-api/console
VITE_ENABLE_SPOONACULAR=false
VITE_SPOONACULAR_API_KEY=your_key_here
